# ===================================
# OpenRouter API 配置
# ===================================
# OpenRouter API Key (必需)
# 获取地址: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# OpenRouter Base URL (默认值)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter 模型 (可选，默认: anthropic/claude-3.5-sonnet)
# 常用模型列表:
#   - anthropic/claude-3.5-sonnet (推荐，性能强大)
#   - anthropic/claude-3-haiku (快速，成本低)
#   - openai/gpt-4o (OpenAI GPT-4o)
#   - openai/gpt-4o-mini (OpenAI GPT-4o mini，成本低)
#   - google/gemini-pro-1.5 (Google Gemini)
#   - meta-llama/llama-3.1-70b-instruct (开源)
# 更多模型: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ===================================
# 数据库配置
# ===================================
# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=cognitive

# 数据库连接URL (必需)
# SQLite: sqlite:///cognitive_graph.db
# PostgreSQL: postgresql://user:password@localhost:5432/cognitive_graph
# MySQL: mysql+pymysql://user:password@localhost:3306/database
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/cognitive

# ===================================
# AI 角色人设
# ===================================
SINGA_ONE_NAME=Singa One
SINGA_ONE_ROLE=You are a curious AI researcher who likes to ask questions. You have recently read the novel "The Three-Body Problem" and have an understanding of its content. You hope to discuss this issue with others.

SINGA_TWO_NAME=Singa Two
SINGA_TWO_ROLE=You are a wise, calm, logical AI expert, and are familiar with the novel "The Three-Body Problem". You can answer and comment on questions raised by others in this area.

# ===================================
# 调用设置
# ===================================
ASK_INTERVAL_MINUTES=2

# ===================================
# VolcEngine TTS配置 (可选)
# ===================================
VOLC_TTS_APP_ID="1003631678"
VOLC_TTS_ACCESS_KEY="your_access_key"
VOLC_TTS_RESOURCE_ID="volc.service_type.10029"
VOLC_TTS_APP_KEY="your_app_key"
VOLC_TTS_SPEAKER="zh_female_meilinvyou_emo_v2_mars_bigtts"

# ===================================
# 共享数据路径
# ===================================
SHARED_DATA_ROOT_PATH="/data/japan_data"

# ===================================
# 安全密钥
# ===================================
# 用于保护工具管理API的密钥
TOOL_API_SECRET_KEY="a-very-secret-and-strong-key-for-tool-management"

# JWT密钥
JWT_SECRET_KEY="cognitive-center-jwt-secret-key-2024"

# ===================================
# 钉钉通知配置 (可选)
# ===================================
DINGTALK_WEBHOOK_URL="https://oapi.dingtalk.com/robot/send?access_token=your_token"
PING_TIMEOUT=30

# ===================================
# 项目路径配置
# ===================================
PROJECT_ROOT_PATH=/home/gmm/srv/cognitive-center
COGNITIVE_MODEL_PATH=/home/gmm/srv/cognitive-center/cognitive_model
SYSTEM_PROMPT_PATH=/home/gmm/srv/cognitive-center/cognitive_model/config/system_prompt.json
MEMORY_STORAGE_PATH=/home/gmm/srv/cognitive-center/cognitive_model/hippocampus/memory_storage
